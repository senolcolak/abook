{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IngestDraftInput",
  "type": "object",
  "required": ["sourceFiles", "sourceType"],
  "properties": {
    "sourceFiles": {
      "type": "array",
      "description": "List of file paths to import",
      "items": { "type": "string" },
      "minItems": 1
    },
    "sourceType": {
      "type": "string",
      "description": "Type of material being imported",
      "enum": ["draft", "notes", "research", "anecdotes", "references"]
    },
    "preserveOriginals": {
      "type": "boolean",
      "description": "Whether to keep original file names",
      "default": true
    }
  }
}
