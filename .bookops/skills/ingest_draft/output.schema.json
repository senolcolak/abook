{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IngestDraftOutput",
  "type": "object",
  "required": ["inventory", "totalFiles", "totalWordCount"],
  "properties": {
    "inventory": {
      "type": "array",
      "description": "List of imported file records",
      "items": {
        "type": "object",
        "required": ["fileName", "destinationPath", "wordCount"],
        "properties": {
          "fileName": { "type": "string" },
          "destinationPath": { "type": "string" },
          "wordCount": { "type": "integer" },
          "fileSize": { "type": "integer", "description": "Size in bytes" },
          "contentType": { "type": "string" }
        }
      }
    },
    "totalFiles": { "type": "integer" },
    "totalWordCount": { "type": "integer" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
