{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillOutput",
  "type": "object",
  "required": ["results", "status"],
  "properties": {
    "results": {
      "type": "object",
      "description": "Skill-specific results",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "filesProcessed": { "type": "integer" },
        "executionTime": { "type": "string" }
      }
    }
  }
}
