{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillInput",
  "type": "object",
  "required": ["sourceFiles"],
  "properties": {
    "sourceFiles": {
      "type": "array",
      "description": "List of file paths to process",
      "items": { "type": "string" },
      "minItems": 1
    },
    "options": {
      "type": "object",
      "description": "Skill-specific options",
      "additionalProperties": true
    }
  }
}
